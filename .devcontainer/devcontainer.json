{
  "name": "VoidForum",
  "image": "mcr.microsoft.com/devcontainers/java:17-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y maven && cd frontend && npm install",
  "remoteUser": "root"
}